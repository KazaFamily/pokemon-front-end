# Copy to .env.local for local development. Leave VITE_API_BASE_URL unset to
# run against the built-in mock API (see src/api/index.ts). Cognito is entirely
# backend-side now (POST /auth/login mints tokens server-side) - the frontend
# never talks to Cognito directly.

VITE_API_BASE_URL=

# WebSocket endpoint for the live lobby (enter/leave, auto-match, challenges).
# Leave unset to fall back to the mock API - the lobby UI shows manual
# opponent-ID entry instead when this isn't configured.
VITE_LOBBY_WS_URL=
